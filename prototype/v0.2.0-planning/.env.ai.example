# Optional OpenAI-compatible model config for the JUGO v0.2 AI session service.
# Copy to .env.ai.local and fill real values on the server. Never commit real keys.

JUGO_AI_HOST=127.0.0.1
JUGO_AI_PORT=18082

# OpenAI-compatible chat completions endpoint.
JUGO_AI_BASE_URL=https://api.openai.com/v1
JUGO_AI_OPENAI_API_KEY=
JUGO_AI_MODEL=gpt-4o-mini
